{
  "name": "moji-splitter",
  "version": "1.3.4",
  "description": "Flexible text splitting utility for CSS animations",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "animation",
    "character",
    "css",
    "grapheme",
    "intl-segmenter",
    "line-breaking",
    "kinsoku",
    "segmenter",
    "split",
    "splitter",
    "splitting",
    "text",
    "typescript",
    "utility",
    "word"
  ],
  "author": "Yusuke Kamiyamane",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/y14e/moji-splitter.git"
  },
  "bugs": {
    "url": "https://github.com/y14e/moji-splitter/issues"
  },
  "homepage": "https://github.com/y14e/moji-splitter#readme",
  "devDependencies": {
    "bun-types": "latest",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
